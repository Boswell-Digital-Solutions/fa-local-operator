{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigitalsolutions.com/schemas/fa-local/gnat-dispatch-envelope.schema.json",
  "title": "FA Local Gnat Dispatch Envelope",
  "description": "Cortex-to-FA Local dispatch envelope for bounded Gnat execution routing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "correlation_id",
    "requester_service",
    "plan",
    "required_capabilities",
    "route_policy"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "GnatDispatchEnvelope.v1"
    },
    "correlation_id": {
      "$ref": "#/$defs/uuid_string"
    },
    "requester_service": {
      "type": "string",
      "const": "cortex"
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "run_id",
        "plan_hash",
        "operation",
        "expected_receipt_schema",
        "shard_count",
        "shards",
        "execution_limits",
        "serial_fallback_allowed"
      ],
      "properties": {
        "contract_version": {
          "type": "string",
          "const": "GnatRunPlan.v1"
        },
        "run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "plan_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "operation": {
          "type": "string",
          "const": "syntax_extract"
        },
        "expected_receipt_schema": {
          "type": "string",
          "const": "gnat-worker-receipt.schema.json"
        },
        "shard_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "shards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/shard"
          }
        },
        "execution_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested_concurrency",
            "max_concurrency",
            "deadline_ms"
          ],
          "properties": {
            "requested_concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "max_concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "deadline_ms": {
              "type": "integer",
              "minimum": 1,
              "maximum": 86400000
            }
          }
        },
        "serial_fallback_allowed": {
          "type": "boolean"
        }
      }
    },
    "required_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported_contract_versions",
        "worker_types",
        "cancellation_policy",
        "deadline_enforced"
      ],
      "properties": {
        "supported_contract_versions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "GnatDispatchEnvelope.v1",
              "GnatRunPlan.v1",
              "GnatWorkerReceipt.v1"
            ]
          }
        },
        "worker_types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/worker_type"
          }
        },
        "cancellation_policy": {
          "type": "string",
          "enum": [
            "cancel_remaining_shards",
            "finish_in_flight_only"
          ]
        },
        "deadline_enforced": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "route_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fa_local_owns_execution_routing",
        "cortex_validates_receipts",
        "retry_policy"
      ],
      "properties": {
        "fa_local_owns_execution_routing": {
          "type": "boolean",
          "const": true
        },
        "cortex_validates_receipts": {
          "type": "boolean",
          "const": true
        },
        "retry_policy": {
          "type": "string",
          "const": "infrastructure_only"
        }
      }
    }
  },
  "$defs": {
    "uuid_string": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "worker_type": {
      "type": "string",
      "enum": [
        "markdown_syntax",
        "plain_text_syntax",
        "pdf_text_syntax",
        "docx_text_syntax",
        "rtf_text_syntax",
        "odt_text_syntax",
        "epub_text_syntax"
      ]
    },
    "shard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shard_id",
        "ordinal",
        "worker_type",
        "source_ref",
        "source_fingerprint_digest",
        "deadline_ms"
      ],
      "properties": {
        "shard_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "worker_type": {
          "$ref": "#/$defs/worker_type"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "source_fingerprint_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "deadline_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400000
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "raw_content_preview"
            ]
          },
          {
            "required": [
              "workflow_id"
            ]
          },
          {
            "required": [
              "executor"
            ]
          }
        ]
      }
    }
  ]
}
